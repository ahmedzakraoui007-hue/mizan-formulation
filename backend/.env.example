# Cloud Database Configuration
# Provide a PostgreSQL connection string here to override the local SQLite mizan.db fallback
# Example format: postgresql://user:password@host:port/database_name
# Note: SQLAlchemy requires 'postgresql://', but 'postgres://' is also supported safely

DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
GEMINI_API_KEY="your-gemini-api-key"
CLERK_JWKS_URL="https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json"
CLERK_ISSUER="https://your-clerk-domain.clerk.accounts.dev"
